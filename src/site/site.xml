<site xmlns="http://maven.apache.org/SITE/2.0.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://maven.apache.org/SITE/2.0.0
      https://maven.apache.org/xsd/site-2.0.0.xsd"
      name="integration-tests-example">

    <skin>
        <groupId>org.sentrysoftware.maven</groupId>
        <artifactId>sentry-maven-skin</artifactId>
        <version>7.0.00</version>
    </skin>

    <custom>
        <bodyClass>sentry-orange</bodyClass>
        <checkImageLinks>false</checkImageLinks>
        <convertImagesToWebp>false</convertImagesToWebp>
        <convertImagesToThumbnails>false</convertImagesToThumbnails>
        <setExplicitImageSize>false</setExplicitImageSize>
        <keywords>IKE, integration test, IT harness, maven-invoker,
                   release cascade, IKE Network</keywords>
    </custom>

    <bannerLeft name="integration-tests-example" href="https://ike.network/">
        <image src="images/ike-logo.svg" alt="IKE"/>
    </bannerLeft>

    <bannerRight name="GitHub &lt;i class='fa-brands fa-github'&gt;&lt;/i&gt;"
        href="https://github.com/IKE-Network/integration-tests-example"/>

    <publishDate format="yyyy-MM-dd"/>

    <body>
        <breadcrumbs>
            <item name="IKE" href="https://ike.network/"/>
            <item name="integration-tests-example" href="index.html"/>
        </breadcrumbs>

        <links>
            <item name="Issues" href="https://github.com/IKE-Network/ike-issues"/>
        </links>

        <menu name="Documentation">
            <item name="Overview"                   href="index.html"/>
            <item name="Software Bill of Materials" href="dependencies.html"/>
        </menu>

        <menu name="Related Sites">
            <item name="workspace-reactor-example (workspace)"
                  href="https://ike.network/workspace-reactor-example/"/>
            <item name="doc-example (sibling)"
                  href="https://ike.network/doc-example/"/>
            <item name="project-example (sibling)"
                  href="https://ike.network/project-example/"/>
            <item name="IKE Platform"
                  href="https://ike.network/ike-platform/"/>
        </menu>

        <menu name="Reports" ref="reports"/>
    </body>
</site>
