<?xml version="1.0" encoding="UTF-8"?>
<!--
  IT — Single-module project at the .git repo root, declares <scm>.

  Sanity check that the lint still permits the original well-formed
  shape — a standalone project at the git boundary with a local
  <scm> block. See IKE-Network/ike-issues#496.
-->
<project xmlns="http://maven.apache.org/POM/4.1.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.1.0
                             http://maven.apache.org/xsd/maven-4.1.0.xsd"
         root="true">
    <modelVersion>4.1.0</modelVersion>

    <groupId>network.ike.examples.it</groupId>
    <artifactId>scm-lint-standalone-pass</artifactId>
    <version>1</version>
    <packaging>pom</packaging>

    <scm>
        <connection>scm:git:https://example.invalid/scm-lint-standalone-pass.git</connection>
        <url>https://example.invalid/scm-lint-standalone-pass</url>
    </scm>
</project>
