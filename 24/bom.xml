    <component type="library" bom-ref="pkg:maven/network.ike.examples/ike-example-its@24-SNAPSHOT?type=pom">
      <publisher>IKE Network</publisher>
      <group>network.ike.examples</group>
      <name>ike-example-its</name>
      <version>24-SNAPSHOT</version>
      <description>End-to-end smoke tests that exercise the IKE Network release
        cascade as external consumers would. Each IT case clones the
        intended usage pattern (doc-only project, java + docs, BOM
        import, ws:create scaffold) in a fresh Maven environment and
        asserts that the build succeeds and produces the expected
        artifacts.</description>
